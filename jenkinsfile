pipeline {
    agent { label 'agent1' }

    environment {
        // NOTE: Move these to Jenkins Credentials for better security!
        TELEGRAM_BOT_TOKEN = '8369729822:AAEfkaixGMP4D2Lf8ft4orBHxKrQwR96hOs'
        TELEGRAM_CHAT_ID = '1145551295'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                sh 'composer install --no-interaction --prefer-dist'
            }
        }

        stage('Setup Environment') {
            steps {
                sh '''
                cp .env.example .env
                php artisan key:generate
                # We skip sudo apt-get here because the Jenkins agent doesn't have permission.
                # The SQLite driver and migrations are now handled by Ansible in the Deploy stage.
                '''
            }
        }


        

        stage('Deploy with Ansible') {
            steps {
               
                // This stage uses the playbooks.yml we fixed to install drivers and migrate
                sh "ansible-playbook -i /etc/ansible/inventory.ini playbook.yml -v"
            }
        }
    }

    post {
        success {
            sh """
            curl -s -X POST https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage \
                 -d chat_id=${TELEGRAM_CHAT_ID} \
                 -d text="✅ Build & Deploy Success for ${env.JOB_NAME} #${env.BUILD_NUMBER}"
            """
        }
        failure {
            sh """
            curl -s -X POST https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage \
                 -d chat_id=${TELEGRAM_CHAT_ID} \
                 -d text="❌ Build Failed for ${env.JOB_NAME} #${env.BUILD_NUMBER}. Check Jenkins console!"
            """
        }
    }
}