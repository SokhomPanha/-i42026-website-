pipeline {
    agent { label 'agent1' }

    environment {
        TELEGRAM_BOT_TOKEN = '8369729822:AAEfkaixGMP4D2Lf8ft4orBHxKrQwR96hOs'
        TELEGRAM_CHAT_ID = '1145551295'
    }

    stages {
        stage('Cleanup & Setup') {
            steps {
                echo 'Cleaning up previous build artifacts...'
                // Clear old node_modules and vite cache to prevent corruption
                sh 'rm -rf node_modules/.vite'
                sh 'cp .env.example .env'
            }
        }

        stage('Build & Prepare') {
            steps {
                echo 'Installing Dependencies...'
                sh 'composer install --no-interaction'
                sh 'php artisan key:generate'
                sh 'npm install'
                
                echo 'Building Assets with Memory Limits...'
                // 1. We use max-old-space-size to limit Node RAM
                // 2. We use UV_THREADPOOL_SIZE=1 to stop the multi-threading that causes Bus Errors
                sh 'NODE_OPTIONS="--max-old-space-size=1024" UV_THREADPOOL_SIZE=1 npm run build'
            }
        }

        stage('Deploy via Ansible') {
            steps {
                echo 'Deploying to 178.128.93.188...'
                sh "ansible-playbook -e 'ansible_ssh_common_args=\"-o StrictHostKeyChecking=no\"' -i /etc/ansible/inventory.ini /etc/ansible/playbook.yml"
            }
        }
    }

    post {
        success {
            sh """
            curl -s -X POST https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage \
                 -d chat_id=${TELEGRAM_CHAT_ID} \
                 -d text="✅ Build & Deploy Success for ${env.JOB_NAME} #${env.BUILD_NUMBER}"
            """
        }
        failure {
            sh """
            curl -s -X POST https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage \
                 -d chat_id=${TELEGRAM_CHAT_ID} \
                 -d text="❌ Build Failed for ${env.JOB_NAME} #${env.BUILD_NUMBER}. Check Jenkins console!"
            """
        }
    }
}